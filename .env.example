# Default: mock UI data + no chain calls
# VITE_ESCROW_USE_MOCK=false

# After `npm run deploy:arc` (or deploy:local) paste addresses from output
# VITE_AGENT_ESCROW_ADDRESS=0x...
# VITE_UNISWAP_PAYOUT_ADDRESS=0x...
# VITE_X402_RELAY_ADDRESS=0x...

# Encode Hardhat MockUniswapXReactor payloads for cross-token verify (default true)
# VITE_UNISWAPX_USE_MOCK_ORDER=false

# Deployer key — required for `deploy:arc` and `deploy:sepolia`
# DEPLOYER_PRIVATE_KEY=0x...

# Arc Testnet RPC (optional — defaults to https://rpc.testnet.arc.network)
# ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Trading API key for quote/order services on supported UniswapX chains
# VITE_UNISWAP_API_KEY
# VITE_OPENAI_KEY
