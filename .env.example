# ----- Frontend (Vite) -----
# JudgeBuddy treasury API
# VITE_HEDERA_API_URL=http://localhost:3001

# Hedera network endpoints used by MetaMask flows
# VITE_HEDERA_EVM_RPC=https://testnet.hashio.io/api
# VITE_HEDERA_MIRROR_BASE=https://testnet.mirrornode.hedera.com
# VITE_HEDERA_USDC_TOKEN_ID=0.0.429274
# VITE_HEDERA_OPERATOR_ID=0.0.x

# Task escrow browser flow
# VITE_ESCROW_CONTRACT_ADDRESS=0x...

# Browser-side treasury helpers
# VITE_TREASURY_CONTRACT_ADDRESS=0x...
# VITE_PRIZE_CLAIM_TOKEN_ADDRESS=0x...

# Legacy escrow demo toggle. Leave unset or false for the treasury platform.
# VITE_ESCROW_USE_MOCK=false

# ----- API / worker / contracts -----
# PORT=3001
# HEDERA_NETWORK=testnet
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/judgebuddy

# Hedera operator used for HCS audit messages
# HEDERA_ACCOUNT_ID=0.0.x
# HEDERA_PRIVATE_KEY=302e...
# HCS_TOPIC_ID=0.0.x

# Hedera JSON-RPC + mirror
# HEDERA_EVM_RPC=https://testnet.hashio.io/api
# HEDERA_MIRROR_BASE=https://testnet.mirrornode.hedera.com
# HEDERA_DRY_RUN=true

# Task escrow server-side storage + optional HederaTaskEscrow sync
# ESCROW_CONTRACT_ADDRESS=0x...
# TASK_STORE_PATH=/absolute/path/tasks.json

# Deployed treasury contracts
# TREASURY_CONTRACT_ADDRESS=0x...
# PRIZE_CLAIM_TOKEN_ADDRESS=0x...
# TREASURY_RELAYER_PRIVATE_KEY=0x...
# TREASURY_AGENT_RELAYER=0x...

# OpenAI worker runtime
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
# WORKER_POLL_INTERVAL_MS=3000

# Deployment wallet for Hardhat scripts
# DEPLOYER_EVM_PRIVATE_KEY=0x...
